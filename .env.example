# Backend API URL
# Keep this empty for local dev — the Vite proxy in vite.config.js handles it.
# In production, set this to your API's base URL (e.g. https://api.taskflow.com)
VITE_API_URL=

# ReCaptcha Public Key
# Must be a v3 SITE KEY. Don't put the secret here!
VITE_RECAPTCHA_SITE_KEY=your_site_key_here
