# Axios base URL for API calls.
# Leave empty (or unset) for local development — the Vite dev server proxy
# will forward /api/* requests to http://localhost:5000 automatically.
#
# In production, set this to your deployed backend URL:
#   VITE_API_URL=https://your-backend.up.railway.app
VITE_API_URL=http://localhost:5000

# RECAPTCHA V3 SITE KEY
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
